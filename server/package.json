{
  "name": "mikane_server",
  "version": "2.4.1-SNAPSHOT.40",
  "type": "module",
  "description": "API server for Mikane",
  "scripts": {
    "build": "rimraf ./build && tsc && npm run copy && cd build && npm ci --omit=dev",
    "esbuild": "rimraf ./build && tsc --noEmit && node ./esbuild.config.js && npm run copyesbuild",
    "copyesbuild": "copyfiles \"./public/**/*\" ./build && copyfiles -u 1 src/api.json ./build",
    "copy": "copyfiles package.json package-lock.json \"./public/**/*\" ./build",
    "start": "node build/index.js",
    "dev": "concurrently --raw \"tsx watch src/index.ts\" \"tsc --noEmit --watch\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "db": "docker-compose -f test_db/docker-compose-test-db.yml -p mikane_test_db up -d"
  },
  "dependencies": {
    "adze": "^2.2.5",
    "cors": "^2.8.5",
    "csrf-sync": "^4.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "pg": "^8.16.3",
    "postmark": "^4.0.5",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.0.15",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "rimraf": "^6.1.2",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "GPL-3.0-or-later"
}
