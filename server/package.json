{
  "name": "mikane_server",
  "version": "2.5.1",
  "type": "module",
  "description": "API server for Mikane",
  "scripts": {
    "build": "rimraf ./build && tsc && npm run copy && cd build && npm ci --omit=dev",
    "esbuild": "rimraf ./build && tsc --noEmit && node ./esbuild.config.js && npm run copyesbuild",
    "copyesbuild": "copyfiles \"./public/**/*\" ./build && copyfiles -u 1 src/api.json ./build",
    "copy": "copyfiles package.json package-lock.json \"./public/**/*\" ./build",
    "start": "node build/index.js",
    "dev": "concurrently --raw \"tsx watch src/index.ts\" \"tsc --noEmit --watch\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "db": "docker-compose -f test_db/docker-compose-test-db.yml -p mikane_test_db up -d"
  },
  "dependencies": {
    "adze": "^2.3.0",
    "cors": "^2.8.6",
    "csrf-sync": "^4.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "postmark": "^4.0.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "GPL-3.0-or-later"
}
